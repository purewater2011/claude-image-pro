# claude-image-pro 配置文件
# 复制到 ~/.claude-image-pro/.env 并填入你的值
# 任何 OpenAI 兼容接口都能用（官方 / 自建中转站 / 第三方网关）

# ====== 必填 ======

# OpenAI 兼容接口的 API key
OPENAI_API_KEY=sk-your-key-here

# OpenAI 兼容接口的 base url（带不带 /v1 都行，脚本会自动规范化）
# 示例：
#   官方：https://api.openai.com/v1
#   作者中转站：https://your-gateway.example.com/v1   ← 在这里替换为你的中转站
OPENAI_BASE_URL=https://your-gateway.example.com/v1

# 出图模型名（默认 gpt-image-2）
OPENAI_IMAGE_MODEL=gpt-image-2


# ====== 可选 ======

# 默认输出尺寸（9:16 抖音竖屏）
# 其他常用：1024x1024 (1:1) / 1536x1024 (3:2) / 2048x2048 (高清方图)
# CLAUDE_IMAGE_PRO_DEFAULT_SIZE=1024x1536
